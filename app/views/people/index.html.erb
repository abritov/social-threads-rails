<% content_for :title, "Find Users" %>

<div class="max-w-2xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
  <h1 class="font-bold text-3xl text-gray-900 mb-6">Find Users</h1>

  <% if @users.any? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 divide-y divide-gray-100">
      <% @users.each do |user| %>
        <div class="flex items-center justify-between p-4 sm:p-5">
          <div class="flex items-center space-x-3">
            <%= link_to person_path(user), class: "flex items-center space-x-3 group" do %>
              <% if user.avatar.attached? %>
                <%= image_tag url_for_active_storage(user.avatar), class: "w-10 h-10 rounded-full object-cover border border-gray-300" %>
              <% else %>
                <div class="w-10 h-10 rounded-full bg-gray-200 flex items-center justify-center text-gray-500 font-bold text-base">
                  <%= user.email.first.capitalize %>
                </div>
              <% end %>
              <span class="font-semibold text-gray-900 group-hover:underline"><%= user.email %></span>
            <% end %>
          </div>

          <%# --- FOLLOW/UNFOLLOW BUTTON (CONDITIONAL) --- %>
          <% if user_signed_in? && current_user != user %> <%# Don't show follow button for self %>
            <div id="user_<%= user.id %>_follow_button_container">
              <%= render "people/follow_button", user: user, current_user: current_user %>
            </div>
          <% elsif !user_signed_in? %>
            <span class="text-gray-500 text-sm">Sign in to follow</span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-center my-10 text-gray-600">No other users found.</p>
  <% end %>
</div>
