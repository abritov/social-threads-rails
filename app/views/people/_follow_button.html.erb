<%# locals: { user: User (the user to follow/unfollow), current_user: User } %>

<% if current_user.following?(user) %>
  <%= button_to "Following", unfollow_person_path(user), {
                method: :delete,
                form: {
                  "up-submit": "",
                  "up-target": "#user_#{user.id}_follow_button_container",
                  data: { turbo: false }
                },
                class: "px-4 py-1.5 border border-gray-300 rounded-full text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors focus:outline-none focus:ring-0",
                data: { turbo: false }
              } %>
<% else %>
  <%= button_to "Follow", follow_person_path(user), {
                method: :post,
                form: {
                  "up-submit": "",
                  "up-target": "#user_#{user.id}_follow_button_container",
                  data: { turbo: false }
                },
                class: "px-4 py-1.5 bg-black text-white rounded-full text-sm font-medium hover:bg-gray-800 transition-colors focus:outline-none focus:ring-0",
                data: { turbo: false }
              } %>
<% end %>
