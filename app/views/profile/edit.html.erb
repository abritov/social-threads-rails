<% content_for :title, "Profile" %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="font-bold text-3xl text-gray-900 dark:text-gray-100">Edit Profile</h1>
    <div class="flex items-center space-x-4"> <%# Added div to group "Back to Feed" and "Log out" buttons %>
      <%= link_to "Back to Feed", posts_path, class: "text-gray-600 dark:text-gray-400 hover:text-black dark:hover:text-gray-100 font-medium" %>
      <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-black dark:focus:ring-gray-600" %>
    </div>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
    <%= form_with model: @user, url: profile_path, method: :patch, local: true, html: { class: "space-y-6" } do |form| %>
      <!-- Avatar Upload -->
      <div class="flex items-center space-x-6">
        <div class="flex-shrink-0">
          <div class="relative">
            <div class="w-20 h-20 bg-gray-200 dark:bg-gray-700 rounded-full flex items-center justify-center overflow-hidden">
              <% if @user.avatar.attached? %>
                <%= image_tag @user.avatar, class: "w-20 h-20 rounded-full object-cover" %>
              <% else %>
                <span class="text-lg font-bold text-gray-400 dark:text-gray-500">
                  <%#= @user.name_initials %>
                </span>
              <% end %>
            </div>
            <div class="absolute bottom-0 right-0 bg-black dark:bg-gray-600 rounded-full p-1">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
          </div>
        </div>
        <div class="flex-1">
          <%= form.label :avatar, "Profile Picture", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= form.file_field :avatar, class: "block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-medium file:bg-black dark:file:bg-gray-700 file:text-white hover:file:bg-gray-800 dark:hover:file:bg-gray-600" %>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">JPG, GIF or PNG. Max size 2MB.</p>
        </div>
      </div>

      <!-- Form Actions -->
      <div class="flex justify-end space-x-3 pt-6 border-t border-gray-200 dark:border-gray-700">
        <%= link_to "Cancel", posts_path, class: "px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-black dark:focus:ring-gray-600" %>
        <%= form.submit "Save Changes", class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-black dark:bg-gray-700 hover:bg-gray-800 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-black dark:focus:ring-gray-600" %>
      </div>
    <% end %>
  </div>

  <!-- Danger Zone -->
  <div class="mt-8 bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-red-200 dark:border-red-900 p-6">
    <h2 class="text-lg font-bold text-red-800 dark:text-red-400 mb-4">Danger Zone</h2>
    
    <div class="flex items-center justify-between">
      <div class="flex-1">
        <h3 class="text-sm font-medium text-gray-900 dark:text-gray-100">Delete Account</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Once you delete your account, there is no going back. Please be certain.</p>
      </div>
      <button class="ml-4 px-4 py-2 border border-red-300 dark:border-red-800 rounded-md shadow-sm text-sm font-medium text-red-700 dark:text-red-400 bg-white dark:bg-gray-800 hover:bg-red-50 dark:hover:bg-red-950 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
        Delete Account
      </button>
    </div>
  </div>
</div>
