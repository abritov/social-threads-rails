<% if flash[:notice].present? %>
  <div data-controller="snackbar" 
       class="fixed bottom-4 left-1/2 -translate-x-1/2 z-50 px-6 py-3 bg-green-600 dark:bg-green-700 text-white rounded-lg shadow-lg transition-all duration-300 ease-out translate-y-4 opacity-0 max-w-md">
    <div class="flex items-center gap-3">
      <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
      </svg>
      <span><%= flash[:notice] %></span>
      <button data-action="click->snackbar#dismiss" class="ml-2 hover:opacity-75">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>
<% elsif flash[:alert].present? %>
  <div data-controller="snackbar" 
       class="fixed bottom-4 left-1/2 -translate-x-1/2 z-50 px-6 py-3 bg-red-600 dark:bg-red-700 text-white rounded-lg shadow-lg transition-all duration-300 ease-out translate-y-4 opacity-0 max-w-md">
    <div class="flex items-center gap-3">
      <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <span><%= flash[:alert] %></span>
      <button data-action="click->snackbar#dismiss" class="ml-2 hover:opacity-75">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>
<% end %>
