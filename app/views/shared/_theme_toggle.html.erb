<div data-controller="theme" style="position: fixed; bottom: 24px; right: 24px; z-index: 9999;">
  <button 
    data-action="click->theme#toggle"
    type="button"
    style="padding: 12px; border-radius: 9999px; background-color: white; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); border: 1px solid #e5e7eb; cursor: pointer;"
    aria-label="Toggle theme"
    onmouseover="this.style.boxShadow='0 20px 25px -5px rgba(0,0,0,0.1)'"
    onmouseout="this.style.boxShadow='0 10px 15px -3px rgba(0,0,0,0.1)'"
  >
    <svg style="width: 24px; height: 24px; color: #1f2937; display: none;" class="sun-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
    </svg>
    <svg style="width: 24px; height: 24px; color: #1f2937; display: block;" class="moon-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
    </svg>
  </button>
</div>
